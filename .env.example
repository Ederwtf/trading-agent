# ─────────────────────────────────────────────
# Copia este archivo a .env y llena los valores
# NUNCA subas .env a GitHub
# ─────────────────────────────────────────────

# Groq API (para bull, bear y synthesis agents)
# Crear key gratis en: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_...
# Modelo (default: Llama 4 Scout — 500K tokens/día, 30K/min, JSON limpio)
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Alpaca Paper Trading
# Crear cuenta en: https://alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXXXX
ALPACA_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Para live trading (SOLO cuando tengas meses de paper positivo)
# ALPACA_BASE_URL=https://api.alpaca.markets
